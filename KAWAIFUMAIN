-- // Helper: make a toggle row with sliding dot
-- Returns the row frame; pass label text and a callback for state change
local function make_toggle_row(parent, pos_y, label_text)
	local row = Instance.new("Frame")
	row.Position = UDim2.new(0, 10, 0, pos_y)
	row.Size = UDim2.new(1, -20, 0, 34)
	row.BackgroundColor3 = Color3.fromRGB(20, 30, 50)
	row.Name = "row_" .. label_text:lower():gsub("%s+", "_")
	row.Parent = parent

	local row_stroke = Instance.new("UIStroke")
	row_stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	row_stroke.Color = Color3.fromRGB(40, 80, 180)
	row_stroke.Thickness = 1.5
	row_stroke.Parent = row

	local row_gradient = Instance.new("UIGradient")
	row_gradient.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 0, 0)),
		ColorSequenceKeypoint.new(0.5, Color3.fromRGB(40, 80, 180)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 0, 0)),
	})
	row_gradient.Rotation = 156.8
	row_gradient.Parent = row_stroke

	local row_corner = Instance.new("UICorner")
	row_corner.Parent = row

	-- Rotating gradient animation
	task.spawn(function()
		local r = 156.8
		while row.Parent do
			r = (r + 0.3) % 360
			row_gradient.Rotation = r
			task.wait(0.03)
		end
	end)

	local text_label = Instance.new("TextLabel")
	text_label.Text = label_text
	text_label.TextColor3 = Color3.fromRGB(255, 255, 255)
	text_label.TextSize = 14
	text_label.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Heavy, Enum.FontStyle.Normal)
	text_label.Size = UDim2.new(1, 0, 1, 0)
	text_label.BackgroundTransparency = 1
	text_label.Parent = row

	-- Toggle switch track
	local toggle_track = Instance.new("Frame")
	toggle_track.Position = UDim2.new(1, -46, 0.5, -9)
	toggle_track.Size = UDim2.new(0, 36, 0, 18)
	toggle_track.BackgroundTransparency = 1
	toggle_track.Name = "toggle_track"
	toggle_track.Parent = row

	local track_corner = Instance.new("UICorner")
	track_corner.CornerRadius = UDim.new(0, 9)
	track_corner.Parent = toggle_track

	local track_stroke = Instance.new("UIStroke")
	track_stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	track_stroke.Color = Color3.fromRGB(40, 80, 180)
	track_stroke.Thickness = 2
	track_stroke.Parent = toggle_track

	local track_stroke_gradient = Instance.new("UIGradient")
	track_stroke_gradient.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 0, 0)),
		ColorSequenceKeypoint.new(0.5, Color3.fromRGB(40, 80, 180)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 0, 0)),
	})
	track_stroke_gradient.Rotation = 155.1
	track_stroke_gradient.Parent = track_stroke

	-- Toggle dot
	local toggle_dot = Instance.new("Frame")
	toggle_dot.Position = UDim2.new(0, 2, 0.5, -7)
	toggle_dot.Size = UDim2.new(0, 14, 0, 14)
	toggle_dot.BackgroundColor3 = Color3.fromRGB(100, 150, 255)
	toggle_dot.Name = "toggle_dot"
	toggle_dot.Parent = toggle_track

	local dot_corner = Instance.new("UICorner")
	dot_corner.CornerRadius = UDim.new(0, 7)
	dot_corner.Parent = toggle_dot

	-- Invisible click button over the row
	local click_btn = Instance.new("TextButton")
	click_btn.Text = ""
	click_btn.Size = UDim2.new(1, 0, 1, 0)
	click_btn.BackgroundTransparency = 1
	click_btn.Parent = row

	-- Toggle state
	local is_on = false

	click_btn.MouseButton1Click:Connect(function()
		is_on = not is_on
		-- Slide dot smoothly
		local target_x = is_on and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
		local dot_color = is_on and Color3.fromRGB(100, 255, 150) or Color3.fromRGB(100, 150, 255)
		tween_service:Create(toggle_dot, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {
			Position = target_x,
			BackgroundColor3 = dot_color,
		}):Play()
		-- dead: no real logic
	end)

	return row
end

