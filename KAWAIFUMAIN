end

-- Toggle Button function
local function setupToggleButton(button, label, onText, offText, initialState, onToggleCallback)
    local isOn = initialState
    label.Text = (isOn and onText) or offText

    local function updateVisuals()
        local targetColor = isOn and Color3.fromRGB(100, 150, 255) or Color3.fromRGB(19, 29, 49)
        local targetPosition = isOn and UDim2.new(1, -16, .5, -7) or UDim2.new(0, 2, .5, -7)
        local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

        TweenService:Create(button.Parent.Frame, tweenInfo, {BackgroundColor3 = targetColor}):Play()
        TweenService:Create(button.Parent.Frame.Frame, tweenInfo, {Position = targetPosition}):Play()
    end

    updateVisuals()

    button.MouseButton1Click:Connect(function()
        isOn = not isOn
        label.Text = (isOn and onText) or offText
        updateVisuals()
        if onToggleCallback then
            onToggleCallback(isOn)
        end
    end)
end

