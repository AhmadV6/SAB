local minimizeTween = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

kinustinksTextButton.MouseButton1Click:Connect(function()
    kinustinksMinimized = not kinustinksMinimized
    if kinustinksMinimized then
        -- shrink first, hide children once collapsed
        TweenService:Create(kinustinksFrame, minimizeTween, {Size = UDim2.new(0, 190, 0, 40)}):Play()
        task.delay(0.25, function()
            for _, child in ipairs(kinustinksContentRows) do
                child.Visible = false
            end
        end)
    else
        -- show children first, then expand
        for _, child in ipairs(kinustinksContentRows) do
            child.Visible = true
        end
        TweenService:Create(kinustinksFrame, minimizeTween, {Size = UDim2.new(0, 190, 0, 290)}):Play()
    end
    kinustinksTextButton.Text = kinustinksMinimized and "+" or "-"
end)

